# ============================================
# Environment Variables
# Copy this file to .env.production and fill in your values
# ============================================

# ============================================
# DATABASE
# ============================================
POSTGRES_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql://bonario:${POSTGRES_PASSWORD}@postgres:5432/bonario_stock

# ============================================
# JWT Authentication
# ============================================
# IMPORTANT: Change this to a random secret in production!
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# ============================================
# ODOO Configuration
# ============================================
ODOO_URL=https://bonario-vietnam.odoo.com
ODOO_DB=bonario-vietnam
ODOO_API_ENDPOINT=https://bonario-vietnam.odoo.com/jsonrpc
ODOO_API_KEY=your_odoo_api_key_here

# ============================================
# Server Configuration
# ============================================
NODE_ENV=production
PORT=4001

# ============================================
# Optional: Redis Cache
# ============================================
# REDIS_URL=redis://localhost:6379

# ============================================
# Optional: Monitoring & Alerting
# ============================================
# ENABLE_MONITORING=true

# ============================================
# Stock Monitor — Variant-level Discontinued
# Comma-separated product.product (variant) IDs whose individual variants are
# discontinued but cannot receive the "Discontinued" tag because sibling variants
# of the same product template are still active. These are merged (union) with
# the Odoo tag-based discontinued set returned by /api/discontinued-products.
# Keep in sync with STOCK_MONITOR_IDS in action-product's .env
# ============================================
# MONITOR_VARIANT_IDS=162056,162057,162061
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id
