# ============================================
# ENVIRONMENT VARIABLES - TEMPLATE
# Bonario Stock Management System
# ============================================
# Copy this file to .env and fill in the values
# Do NOT commit .env files with real credentials!
# ============================================

# Server
NODE_ENV=development        # development | staging | production
PORT=4001                   # Express server port

# Odoo API Configuration
ODOO_API_ENDPOINT=https://your-company.odoo.com/jsonrpc
ODOO_DATABASE=your-database
ODOO_USER_ID=2              # Odoo user ID for API access
ODOO_API_KEY=               # API key from Odoo user settings

# Security
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes
RATE_LIMIT_MAX=100          # Max requests per window

# HMAC Request Signing
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_SECRET=                 # 64-character hex string for HMAC signing

# Logging
LOG_LEVEL=info              # debug | info | warn | error

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5177
